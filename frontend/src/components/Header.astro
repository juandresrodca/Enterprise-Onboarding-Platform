---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<header class="mb-6 flex flex-wrap items-center gap-3">
  <div class="min-w-0 flex-1">
    <h1 class="text-lg font-semibold tracking-tight">{title}</h1>
    {subtitle && <p class="mt-0.5 text-sm text-slate-500 dark:text-slate-400">{subtitle}</p>}
  </div>

  <button id="theme-toggle" class="btn-ghost px-2" aria-label="Toggle dark mode" type="button">
    <svg class="size-[18px] dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor"
      stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
      <circle cx="12" cy="12" r="4.5"/>
      <path d="M12 2.5v2M12 19.5v2M2.5 12h2M19.5 12h2M5 5l1.4 1.4M17.6 17.6L19 19M19 5l-1.4 1.4M6.4 17.6L5 19"/>
    </svg>
    <svg class="hidden size-[18px] dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor"
      stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M20.5 14.5A8.5 8.5 0 019.5 3.5a8.5 8.5 0 1011 11z"/>
    </svg>
  </button>

  <div class="flex items-center gap-2.5 rounded-lg border border-slate-200 bg-white py-1.5 pr-2 pl-1.5
    dark:border-slate-800 dark:bg-slate-900">
    <span id="user-avatar"
      class="flex size-7 items-center justify-center rounded-full bg-accent-700/10 text-xs font-semibold
        text-accent-800 dark:bg-accent-400/10 dark:text-accent-300">–</span>
    <span class="leading-tight">
      <span id="user-name" class="block max-w-40 truncate text-[13px] font-medium">…</span>
      <span id="user-role" class="block text-[11px] text-slate-500 dark:text-slate-400"></span>
    </span>
    <button id="logout-btn" class="btn-ghost btn-sm" type="button" aria-label="Sign out">
      <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"
        stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/>
      </svg>
    </button>
  </div>
</header>
