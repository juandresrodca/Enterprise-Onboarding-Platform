# Enterprise Identity Onboarding - backend configuration
# Copy to .env and adjust. Every value can also be set as an environment variable.

# demo | production
EIO_ENVIRONMENT=demo
EIO_DEMO_MODE=true

# REQUIRED in production: stable secret for session signing (64+ random chars).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
#EIO_SECRET_KEY=

EIO_SESSION_TIMEOUT_MINUTES=30
# Set true when serving over HTTPS (production requirement).
EIO_COOKIE_SECURE=false
EIO_CORS_ORIGINS=["http://localhost:4321","http://127.0.0.1:4321"]

# --- Microsoft Entra ID sign-in (production) ---------------------------------
#EIO_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
#EIO_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
#EIO_ENTRA_CLIENT_SECRET=<from Key Vault / secret store - never commit>
#EIO_ENTRA_REDIRECT_URI=https://onboarding.example.com/api/auth/entra/callback

# --- Directory -----------------------------------------------------------------
EIO_DOMAIN_DNS=northwind.local
EIO_DOMAIN_NETBIOS=NORTHWIND
EIO_UPN_SUFFIX=northwind.com
EIO_DEFAULT_HOME_BASE_PATH=\\FS01\Home

# --- PowerShell (production mode) ------------------------------------------------
EIO_POWERSHELL_EXECUTABLE=pwsh
EIO_SCRIPT_TIMEOUT_SECONDS=180
EIO_MAX_CONCURRENT_SCRIPTS=4

# --- Password policy ---------------------------------------------------------------
EIO_PWD_MIN_LENGTH=12
EIO_PWD_GENERATED_LENGTH=16
